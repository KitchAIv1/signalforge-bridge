{
  "name": "signalforge-bridge",
  "version": "1.0.0",
  "description": "SignalForge Bridge — listens to signals table, runs risk pipeline, executes on OANDA",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "test:connection": "tsx src/test/testOandaConnection.ts",
    "audit:latency": "tsx scripts/audit/bridgeLatencyAudit.ts",
    "amd-backfill": "ts-node scripts/amdBackfill.ts",
    "amd-historical": "tsx scripts/amdHistoricalBacktest.ts",
    "amd-historical-csv": "tsx scripts/amdHistoricalBacktest.ts --emit-csv-from-db",
    "amd-simulate": "tsx scripts/amdSimulation.ts",
    "amd-detect": "tsx src/services/AmdDetectorService.ts",
    "dashboard:dev": "cd dashboard && npm run dev",
    "dashboard:build": "cd dashboard && npm run build",
    "regime-vs-amd-backtest": "tsx scripts/regimeVsAmdDirectionBacktest.ts",
    "amd-conflicted-weak-d1": "tsx scripts/amdConflictedWeakD1Backtest.ts",
    "amd-conflicted-shifted-audit": "tsx scripts/amdConflictedWeakD1/shiftedContaminationAudit.ts",
    "test": "node --import tsx --test src/connectors/broker/normalizeBrokerTimestamp.test.ts src/services/amdDetector/amdDetectionLock.test.ts src/connectors/broker/brokerClient.test.ts src/connectors/broker/mt5DealHistory.test.ts src/connectors/broker/mt5FillPrice.test.ts src/connectors/broker/mt5OrderHelpers.test.ts scripts/vtConcurrencySim/replayPolicies.test.ts",
    "mt5:probe-short-lot": "tsx scripts/probeMt5ShortLotSign.ts",
    "mt5:list-symbols": "tsx scripts/mt5ListSymbols.ts",
    "mt5:sizing-study": "tsx scripts/mt5SizingStudy.ts",
    "mt5:fade-basis-report": "tsx scripts/mt5FadeBasisReport.ts",
    "test:mt5-connection": "tsx scripts/testMt5Connection.ts",
    "vt:concurrency-sim": "tsx scripts/vtConcurrencySim.ts",
    "amd-judas-window-backtest": "tsx scripts/amdJudasWindowBacktest.ts",
    "amd-outcome-backfill": "tsx scripts/amdOutcomeBackfillFromChartData.ts",
    "amd-multi-signal-backtest": "tsx scripts/amdMultiSignalDirectionBacktest.ts",
    "amd-dol-backtest": "tsx scripts/amdDolDirectionBacktest.ts",
    "asian-close-bias-backfill": "tsx scripts/asianCloseBiasBackfill.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "dotenv": "^16.4.0",
    "metaapi.cloud-sdk": "^29.3.3",
    "node-cron": "^4.2.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/node-cron": "^3.0.11",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  }
}
