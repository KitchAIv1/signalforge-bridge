# Supabase (same project as engines; service role for bridge tables)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key

# OANDA v20 (practice); token from OANDA Hub → Tools → API
OANDA_API_TOKEN=your_oanda_token
OANDA_ACCOUNT_ID=your_oanda_account_id
# Lane B Phase 2 experiment (AUD_NEWWWW)
OANDA_PHASE2_ACCOUNT_ID=101-001-38709456-003
# ENGINE_AMD dedicated distribution account (isolated from Omega main account)
AMD_OANDA_ACCOUNT_ID=101-001-38709456-004
AMD_DISTRIBUTION_ENABLED=true
# S0/S1 pip trail from peak (default 5; set 2.5 to rollback)
AMD_PIP_TRAIL_PIPS=5
OANDA_ENVIRONMENT=practice

# AUD_FADE optional separate OANDA practice account
AUDUSD_FADE_OANDA_ACCOUNT_ID=

# PDL Window live engine (shares Fade OANDA + MT5). Default off.
PDL_WINDOW_ENABLED=false
# Optional risk fraction (default 0.02 = 2%). Combined with bridge_engines.weight.
# PDL_WINDOW_RISK_PCT=0.02

# Table name engines write to (verify from engine signalLogger)
SIGNAL_TABLE=signals

# MT5 / MetaApi (VT Markets) — disabled until ops completes docs/MT5_SETUP.md
MT5_ENABLED=false
METAAPI_TOKEN=
METAAPI_OMEGA_ACCOUNT_ID=
METAAPI_FADE_ACCOUNT_ID=
# Optional override for ALPHAOMEGA VT live book (else UUID from Settings bind → bridge_brokers.account_id)
METAAPI_AO_ACCOUNT_ID=
METAAPI_REGION=london
VT_SYMBOL_SUFFIX=-STD

# Optional: Slack/Discord webhook for alerts
ALERT_WEBHOOK_URL=

LOG_LEVEL=info
NODE_ENV=development
